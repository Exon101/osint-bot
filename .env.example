# Required
TELEGRAM_TOKEN=your_bot_token_from_botfather

# Optional API Keys (Free tiers)
IPINFO_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
HUNTER_API_KEY=
ABUSEIPDB_API_KEY=
GITHUB_TOKEN=

# Proxy Configuration (optional)
# Single proxy URL
PROXY_URL=
# Comma-separated list of proxies
PROXY_LIST=
# Auto-enable proxy on startup (true/false)
PROXY_ENABLED=false
# Rotation mode: sequential | random | failover
PROXY_ROTATION=sequential
# URL used to test proxy connectivity
PROXY_TEST_URL=https://httpbin.org/ip
# Proxy test timeout in seconds
PROXY_TEST_TIMEOUT=10

# Feature Flags (optional)
ENABLE_CODE_RUNNER=true
ENABLE_PASSWORD_GEN=true
